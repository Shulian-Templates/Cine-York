{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debuggear Consigna Base",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/src/index.ts",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--enable-source-maps"
      },
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**",
        "**/src/lib/**",
        "**/src/frontend/websocket.js",
        "**/promises.js",
        "<node_internals>/internal/**"
      ],
      "smartStep": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debuggear Consigna Bonus",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/src/bonus.ts",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "env": {
        "NODE_OPTIONS": "--enable-source-maps"
      },
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**",
        "**/src/lib/**",
        "**/src/frontend/websocket.js",
        "**/promises.js",
        "<node_internals>/internal/**"
      ],
      "smartStep": true
    }
  ]
}
